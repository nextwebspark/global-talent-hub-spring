{
  "permissions": {
    "allow": [
      "Bash(break)"
    ],
    "deny": [
      "Read(./src/main/resources/application-local.properties)",
      "Read(**/application-local.properties)",
      "Read(**/*.properties.local)",
      "Read(**/*.yml.local)",
      "Read(./.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*-vertex-key.json)",
      "Read(**/*-sa-key.json)",
      "Read(**/gcp-key*.json)",
      "Read(./railway-vertex-key.json)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(sudo *)",
      "Bash(chmod -R *)",
      "Bash(curl *| sh)",
      "Bash(curl *| bash)",
      "Bash(wget *| sh)",
      "Bash(wget *| bash)",
      "Bash(mvn *deploy*)",
      "Bash(gcloud run deploy*)"
    ]
  },
  "sandbox": {
    "credentials": {
      "files": [
        { "path": "./src/main/resources/application-local.properties", "mode": "deny" },
        { "path": "./railway-vertex-key.json", "mode": "deny" }
      ]
    }
  }
}
