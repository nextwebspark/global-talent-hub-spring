# ── LOCAL profile TEMPLATE — committed. Copy to application-local.properties ──
#   cp src/main/resources/application-local.properties.example \
#      src/main/resources/application-local.properties
# Then fill in real values. The real file is gitignored.
#
# Local dev connects to Cloud SQL (bright-gcc) through the Cloud SQL Auth Proxy.
# Start it first (needs gcloud auth / ADC), then run the app:
#   cloud-sql-proxy hak-talent-mapping:us-central1:bright-gcc --port 5432
#   SPRING_PROFILES_ACTIVE=dev,local mvn spring-boot:run

spring.datasource.url=jdbc:postgresql://127.0.0.1:5432/brightdata
spring.datasource.username=postgres
spring.datasource.password=

# App-owned JWT signing secret (HS256, >= 32 bytes). Required.
app.jwt.secret=
# Token lifetime in seconds (optional; defaults to 604800 = 7 days).
# app.jwt.expiry-seconds=604800

spring.ai.vertex.ai.gemini.project-id=
spring.ai.vertex.ai.gemini.location=us-central1
spring.ai.vertex.ai.gemini.credentials-uri=file:/absolute/path/to/gcp-sa-key.json

# app.clockwork.api-key=
# app.clockwork.api-secret=
# app.clockwork.firm-key=
# app.clockwork.firm-slug=
